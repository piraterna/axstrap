diff --git a/src/utmp.h b/src/utmp.h
new file mode 100644
index 0000000..6eeb54a
--- /dev/null
+++ b/src/utmp.h
@@ -0,0 +1,71 @@
+#ifndef SYSVINIT_AURIX_UTMP_H
+#define SYSVINIT_AURIX_UTMP_H
+
+/*
+ * sysvinit expects the legacy <utmp.h> API (struct utmp + setutent(),
+ * getutent(), pututline(), updwtmp(), ...).
+ *
+ * mlibc (used by aurix) provides <utmpx.h> and the utmpx APIs instead.
+ * Provide a small compatibility shim by mapping utmp -> utmpx.
+ */
+
+#if defined(__has_include)
+#  if __has_include(<mlibc-config.h>)
+#    include <mlibc-config.h>
+#    define SYSVINIT_HAS_MLIBC 1
+#  endif
+#endif
+
+#if defined(SYSVINIT_HAS_MLIBC)
+#  include <utmpx.h>
+
+  /* Make sysvinit's "struct utmp" refer to mlibc's struct utmpx. */
+#  define utmp utmpx
+
+  /* Size macros expected by sysvinit code. */
+#  ifndef UT_LINESIZE
+#    define UT_LINESIZE __UT_LINESIZE
+#  endif
+#  ifndef UT_NAMESIZE
+#    define UT_NAMESIZE __UT_NAMESIZE
+#  endif
+#  ifndef UT_HOSTSIZE
+#    define UT_HOSTSIZE __UT_HOSTSIZE
+#  endif
+
+  /* File paths expected by sysvinit code. */
+#  ifndef UTMP_FILE
+#    define UTMP_FILE UTMPX_FILE
+#  endif
+#  ifndef WTMP_FILE
+#    define WTMP_FILE WTMPX_FILE
+#  endif
+
+  /* Field aliases used by sysvinit (utmp vs utmpx / libc differences). */
+#  ifndef ut_time
+#    define ut_time ut_tv.tv_sec
+#  endif
+#  ifndef ut_name
+    /* Some code uses ut_name (glibc); utmpx uses ut_user. */
+#    define ut_name ut_user
+#  endif
+#  ifndef ut_addr
+    /* Historic ut_addr (IPv4) maps to first v6 word in utmpx. */
+#    define ut_addr ut_addr_v6[0]
+#  endif
+
+  /* Function aliases. */
+#  define setutent  setutxent
+#  define endutent  endutxent
+#  define getutent  getutxent
+#  define getutid   getutxid
+#  define getutline getutxline
+#  define pututline pututxline
+#  define updwtmp   updwtmpx
+#  define utmpname  utmpxname
+
+#else
+#  include <utmp.h>
+#endif
+
+#endif /* SYSVINIT_AURIX_UTMP_H */
